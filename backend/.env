GROQ_API_KEY=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

# Optional: multiple API keys for failover when one key/model is rate-limited.
# Format: comma-separated keys.
# Comma-separated model rotation order. The service rotates start model per request,
# and retries the next model automatically on rate limit or model failure.
LLM_MODEL_ROTATION=meta-llama/llama-4-scout-17b-16e-instruct,llama-3.3-70b-versatile,moonshotai/kimi-k2-instruct,llama-3.1-8b-instant,qwen/qwen3-32b

# TLS options for environments with self-signed/intercepting corporate cert chains.
# Prefer setting LLM_CA_BUNDLE to your corporate CA file and keep LLM_TLS_INSECURE=false.
LLM_TLS_INSECURE=true
# LLM_CA_BUNDLE=C:/path/to/corporate-ca.pem

# Optional strict source validation
STRICT_DATA_QUALITY=true
