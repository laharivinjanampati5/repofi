# Strict LLM mode configuration
# Copy this to backend/.env and set your actual key.

GROQ_API_KEY=your_groq_api_key_here

# Optional: multiple API keys for failover when one key/model is rate-limited.
# Format: comma-separated keys.
LLM_API_KEYS=key_one,key_two,key_three

# Comma-separated model rotation order. The service rotates start model per request,
# and retries the next model automatically on rate limit or model failure.
LLM_MODEL_ROTATION=llama-3.3-70b-versatile,mixtral-8x7b-32768,llama3-70b-8192

# TLS options (for corporate/self-signed interception environments)
# Prefer CA bundle over insecure mode.
LLM_TLS_INSECURE=false
# LLM_CA_BUNDLE=/path/to/corporate-ca.pem

# Optional strict source validation
STRICT_DATA_QUALITY=true
